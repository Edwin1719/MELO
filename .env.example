# ─────────────────────────────────────────────────────────────────
# MELO — Configuración del pipeline
# ─────────────────────────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores según tu entorno.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────

# ── Modelo para el NPC estratega / reportero ─────────────────────
# Modelo local vía Ollama (recomendado)
NPC_MODEL=qwen2.5-coder:7b
NPC_PROVIDER=ollama

# Para usar OpenAI en lugar de modelo local:
# NPC_MODEL=gpt-4o-mini
# NPC_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Temperatura del NPC (0.0 = determinista, 1.0 = creativo)
NPC_TEMPERATURE=0.3

# ── Pipeline ─────────────────────────────────────────────────────
# Tamaño del conjunto de test (0.0 - 1.0)
TEST_SIZE=0.2

# Semilla aleatoria para reproducibilidad
RANDOM_STATE=42

# Método de escalado por defecto: standard, minmax, robust
SCALE_METHOD=standard

# Número de folds para validación cruzada
CV_FOLDS=5

# Método de ensemble: weighted, vote
ENSEMBLE_METHOD=weighted

# Número de mejores modelos para el ensemble
N_TOP_ENSEMBLE=3

# ── Balanceo ─────────────────────────────────────────────────────
# Estrategia: auto, smote, adasyn, smote_enn, class_weight, none
BALANCE_METHOD=auto

# ── Output ───────────────────────────────────────────────────────
# Directorio donde se guardan los reportes
OUTPUT_DIR=output

# Guardar reporte en archivo (true/false)
SAVE_REPORT=true
